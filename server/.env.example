PORT=3001
NODE_ENV=development

# Required in production (min 32 random characters). Dev may omit (uses a local placeholder).
JWT_SECRET=

# Comma-separated allowed browser origins, e.g. https://app.example.com
CORS_ORIGIN=http://localhost:5173

# Optional: POST /api/auth/seed-partner requires header X-Seed-Partner-Secret. In production, if unset, seeding is disabled.
# SEED_PARTNER_SECRET=

# Behind nginx/render/etc. so rate limits see the real client IP
# TRUST_PROXY=true

# Emergency only: allow JWT in ?token= (leaks in URLs). Prefer Authorization: Bearer from the app.
# ALLOW_AUTH_QUERY_TOKEN=false

# Vite `dist` folder: absolute path, or path relative to process.cwd() (usually the `server/` directory).
# Default resolves to the repo root `../dist` when the server is started from `server/`.
# FRONTEND_DIST=../dist

# Local: serve the built SPA from dist without NODE_ENV=production (single-port smoke test after `npm run build` at repo root)
# SERVE_STATIC=true
